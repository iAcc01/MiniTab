{
  "manifest_version": 3,
  "name": "Mini_Tab - 书签管理",
  "version": "1.0.0",
  "description": "智能书签管理与 Prompt 工具，替代你的新标签页",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.supabase.co/*"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
