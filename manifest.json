{
  "key": "",
  "manifest_version": 3,
  "name": "MiniTab",
  "version": "1.3.1",
  "description": "智能书签管理与新标签页，发现优质网站",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://raw.githubusercontent.com/*"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
